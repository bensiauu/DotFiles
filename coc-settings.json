{
  "languageserver": {
    "typescript": {
      "command": "typescript-language-server",
      "args": ["--stdio"],
      "filetypes": [
        "typescript",
        "typescriptreact",
        "javascript",
        "javascriptreact"
      ],
      "initializationOptions": {
        "preferences": {
          "importModuleSpecifier": "relative"
        }
      }
    }
  }
}
